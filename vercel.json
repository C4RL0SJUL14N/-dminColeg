{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm ci",
  "buildCommand": "npm run build:api-gateway && npm run build:web",
  "outputDirectory": "dist/apps/web",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api?path=:path*"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "includeFiles": "dist/apps/api-gateway/**",
      "maxDuration": 30
    }
  }
}
