# Entorno
NODE_ENV=development

# Base de datos Supabase / PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@db.example.supabase.co:5432/postgres
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_LOGGING=false

# Puertos de apps
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
ACCESS_CONTROL_SERVICE_PORT=3002
INSTITUTION_SERVICE_PORT=3003
IDENTITY_SERVICE_PORT=3004

# JWT y autenticacion
# Equivalencias semanticas:
# JWT_SECRET -> JWT_ACCESS_SECRET
# JWT_REFRESH_SECRET -> JWT_REFRESH_SECRET
# TOKEN_EXPIRATION -> JWT_ACCESS_TTL
# REFRESH_TOKEN_EXPIRATION -> JWT_REFRESH_TTL
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
AUTH_MAX_FAILED_ATTEMPTS=5
PASSWORD_RESET_TTL_MINUTES=30

# Google OIDC
GOOGLE_OIDC_ENABLED=false
GOOGLE_OIDC_ISSUER=https://accounts.google.com
GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_CLIENT_SECRET=
GOOGLE_OIDC_REDIRECT_URI=http://localhost:3000/auth/google/callback
