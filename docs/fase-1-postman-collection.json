    {
      "name": "04 Access Control",
      "item": [
        {
          "name": "04.01 Contexto De Acceso",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/usuarios/{{usuarioId}}/contexto-acceso",
            "description": "Consulta contexto de acceso y resuelve ids actuales de rol y perfil."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('contexto tiene perfiles y roles', () => {",
                  "  pm.expect(json.data).to.have.property('perfiles');",
                  "  pm.expect(json.data).to.have.property('roles');",
                  "});",
                  "const perfil = (json.data.perfiles || [])[0];",
                  "const rol = (json.data.roles || [])[0];",
                  "if (perfil?.tipoPerfilId) pm.environment.set('tipoPerfilId', perfil.tipoPerfilId);",
                  "if (rol?.id) pm.environment.set('rolId', rol.id);",
                  "console.log('tipoPerfilId resolved:', perfil ? perfil.tipoPerfilId : null);",
                  "console.log('rolId resolved:', rol ? rol.id : null);"
                ]
              }
            }
          ]
        },
