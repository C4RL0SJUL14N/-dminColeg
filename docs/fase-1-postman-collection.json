        {
          "name": "04.04 Asignar Rol",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/usuarios/{{usuarioId}}/roles",
            "description": "Valida asignacion idempotente usando el rol actual del superadministrador. Limitacion: no existe endpoint para listar roles arbitrarios.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rolId\": \"{{rolId}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('status 200 o 201', () => pm.expect([200, 201]).to.include(pm.response.code));",
                  "pm.test('rol asignado', () => {",
                  "  pm.expect(json.data.rolId).to.eql((pm.environment.get('rolId') || pm.collectionVariables.get('rolId')));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "04.05 Asignar Administrador App Opcional",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/instituciones/{{institucionId}}/administradores-app",
            "description": "Cobertura opcional. Requiere un usuario institucional semilla en adminAppTargetUserId porque la API de Fase 1 no crea usuarios institucionales.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuarioId\": \"{{adminAppTargetUserId}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const runOptional = (pm.environment.get('runOptionalAdminApp') || 'false').toLowerCase() === 'true';",
                  "const target = pm.environment.get('adminAppTargetUserId') || pm.collectionVariables.get('adminAppTargetUserId');",
                  "if (!runOptional || !target) {",
                  "  console.log('Skipping optional admin app assignment');",
                  "  pm.environment.set('skipCurrentRequest', '04.05');",
                  "  if (pm.execution && typeof pm.execution.skipRequest === 'function') {",
                  "    pm.execution.skipRequest();",
                  "  }",
                  "} else {",
                  "  pm.environment.unset('skipCurrentRequest');",
                  "  pm.environment.set('adminAppTargetUserId', target);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.environment.get('skipCurrentRequest') === '04.05') {",
                  "  pm.test('optional admin app request skipped', () => pm.expect(true).to.eql(true));",
                  "  pm.environment.unset('skipCurrentRequest');",
                  "} else {",
                  "  let json = {};",
                  "  try { json = pm.response.json(); } catch (e) { json = {}; }",
                  "  pm.test('status 200 o 201', () => pm.expect([200, 201]).to.include(pm.response.code));",
                  "  pm.test('rol administrador institucional visible en contexto', () => {",
                  "    pm.expect(json.data).to.be.an('object');",
                  "    pm.expect(json.data.roles.some(r => r.codigo === 'administrador_app_institucion')).to.eql(true);",
                  "  });",
                  "  console.log('admin app status:', pm.response.code);",
                  "  console.log('admin app body:', pm.response.text());",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
