  "item": [
    {
      "name": "00 Auth",
      "item": [
        {
          "name": "00.01 Login Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/login",
            "description": "Autentica el superadministrador y captura tokens y contexto.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"{{adminEmail}}\",\n  \"contrasena\": \"{{adminPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('status 200 o 201', () => pm.expect([200, 201]).to.include(pm.response.code));",
                  "pm.test('envelope exitoso', () => {",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json).to.have.property('timestamp');",
                  "});",
                  "pm.test('tokens presentes', () => {",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.data.refreshToken).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('contexto de acceso presente', () => {",
                  "  pm.expect(json.data.contextoAcceso).to.be.an('object');",
                  "  pm.expect(json.data.contextoAcceso.usuarioId).to.be.a('string');",
                  "});",
                  "pm.environment.set('accessToken', json.data.accessToken);",
                  "pm.environment.set('refreshToken', json.data.refreshToken);",
                  "pm.environment.set('usuarioId', json.data.contextoAcceso.usuarioId);",
                  "const primerRol = (json.data.contextoAcceso.roles || [])[0];",
                  "if (primerRol?.id) pm.environment.set('rolId', primerRol.id);",
                  "console.log('login refresh token length:', (json.data.refreshToken || '').length);"
                ]
              }
            }
          ]
        },
        {
          "name": "00.02 Refresh",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/refresh",
            "description": "Renueva access y refresh token.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) { json = {}; }",
                  "pm.test('status 200 o 201', () => pm.expect([200, 201]).to.include(pm.response.code));",
                  "pm.test('response body parseable', () => pm.expect(json).to.be.an('object'));",
                  "pm.test('envelope de refresh presente', () => {",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json).to.have.property('timestamp');",
                  "});",
                  "pm.test('nuevos tokens presentes', () => {",
                  "  pm.expect(json.data).to.be.an('object');",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.data.refreshToken).to.be.a('string').and.not.empty;",
                  "});",
                  "if (json.data && json.data.accessToken) pm.environment.set('accessToken', json.data.accessToken);",
                  "if (json.data && json.data.refreshToken) pm.environment.set('refreshToken', json.data.refreshToken);",
                  "console.log('refresh status:', pm.response.code);",
                  "console.log('refresh body:', pm.response.text());",
                  "console.log('refreshToken length sent:', (pm.environment.get('refreshToken') || '').length);"
                ]
              }
            }
          ]
        },
        {
          "name": "00.03 Sesiones",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
