{
  "name": "admincoleg-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo NestJS para plataforma educativa multiinstitucion",
  "scripts": {
    "build": "nest build",
    "build:api-gateway": "nest build api-gateway",
    "build:auth-service": "nest build auth-service",
    "build:access-control-service": "nest build access-control-service",
    "build:institution-service": "nest build institution-service",
    "build:identity-service": "nest build identity-service",
    "build:academic-structure-service": "nest build academic-structure-service",
    "build:enrollment-service": "nest build enrollment-service",
    "build:staff-service": "nest build staff-service",
    "build:attendance-service": "nest build attendance-service",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "start:api-gateway": "nest start api-gateway",
    "start:auth-service": "nest start auth-service",
    "start:access-control-service": "nest start access-control-service",
    "start:institution-service": "nest start institution-service",
    "start:identity-service": "nest start identity-service",
    "start:academic-structure-service": "nest start academic-structure-service",
    "start:enrollment-service": "nest start enrollment-service",
    "start:staff-service": "nest start staff-service",
    "start:attendance-service": "nest start attendance-service",
    "start:dev:api-gateway": "nest start api-gateway --watch",
    "start:dev:auth-service": "nest start auth-service --watch",
    "start:dev:access-control-service": "nest start access-control-service --watch",
    "start:dev:institution-service": "nest start institution-service --watch",
    "start:dev:identity-service": "nest start identity-service --watch",
    "start:dev:academic-structure-service": "nest start academic-structure-service --watch",
    "start:dev:enrollment-service": "nest start enrollment-service --watch",
    "start:dev:staff-service": "nest start staff-service --watch",
    "start:dev:attendance-service": "nest start attendance-service --watch",
    "start:dev:web": "vite --config apps/web/vite.config.ts",
    "start:web": "vite preview --config apps/web/vite.config.ts --host 127.0.0.1 --port 4173",
    "test:audit": "ts-node --prefer-ts-exts -r tsconfig-paths/register tests/run-audit-tests.ts",
    "test:access-control": "ts-node --prefer-ts-exts -r tsconfig-paths/register tests/run-access-control-tests.ts",
    "test:academic-authorization": "ts-node --prefer-ts-exts -r tsconfig-paths/register tests/run-academic-authorization-tests.ts",
    "test:enrollment-authorization": "ts-node --prefer-ts-exts -r tsconfig-paths/register tests/run-enrollment-authorization-tests.ts",
    "test:transfer-workflow": "ts-node --prefer-ts-exts -r tsconfig-paths/register tests/run-transfer-workflow-tests.ts",
    "test:staff-authorization": "ts-node --prefer-ts-exts -r tsconfig-paths/register tests/run-staff-authorization-tests.ts",
    "test:attendance-authorization": "ts-node --prefer-ts-exts -r tsconfig-paths/register tests/run-attendance-authorization-tests.ts",
    "test:fase1": "newman run docs/fase-1-postman-collection.json -e docs/fase1.local.postman_environment.json --reporters cli --timeout-request 15000 --timeout 180000 --bail",
    "test:fase1:json": "newman run docs/fase-1-postman-collection.json -e docs/fase1.local.postman_environment.json --reporters cli,json --reporter-json-export docs/reports/fase1-report.json --timeout-request 15000 --timeout 180000 --bail",
    "audit:prod": "npm audit --omit=dev",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "commonjs",
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/typeorm": "^11.0.3",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.25.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.31"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "newman": "^6.2.2",
    "prettier": "^3.9.5",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5"
  }
}
